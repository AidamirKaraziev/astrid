# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
# true — весь Bot API через TELEGRAM_PROXY_URL; false — прямое подключение
USE_VPN=false

# Database
DATABASE_URL=postgresql+asyncpg://astra:astra@localhost:5432/astra

# GeoNames: автозагрузка справочника городов при старте, если places пуста
GEONAMES_AUTO_IMPORT=true

# Redis
REDIS_URL=redis://localhost:6379/0
# FSM бота: redis (нужен docker redis) или memory (без Redis)
FSM_STORAGE=redis

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_BOT_USERNAME=YourAstraBot
TELEGRAM_MODE=polling
# Proxy только для Bot API (SOCKS5 или HTTP). НЕ tg://proxy (это MTProto для приложения Telegram)
# TELEGRAM_PROXY_URL=socks5://user:pass@proxy.example.com:1080
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/v1/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=random-secret-string
# Геолокация на Desktop (HTTPS). Пример: https://xxxx.ngrok-free.app
# В @BotFather: /setdomain → тот же домен без пути
# WEBAPP_BASE_URL=https://xxxx.ngrok-free.app

# Points
POINTS_DAILY_VISIT=7
REFERRAL_BONUS_REFERRER=50
REFERRAL_BONUS_INVITEE=10

# Notifications
NOTIFICATION_HOUR=9
NOTIFICATION_MINUTE=0

# RabbitMQ (фоновые задачи: натал, предсказания, рассылка)
RABBITMQ_URL=amqp://astra:astra@localhost:5672/
RABBITMQ_ENABLED=true
RABBITMQ_PREFETCH=8

# Ollama — self-hosted LLM (хороший русский: qwen2.5:7b)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT_SECONDS=120

# Sentry (optional)
# SENTRY_DSN=


curl -s http://127.0.0.1:9090/proxies/PROXY \
  -H "Authorization: Bearer aidamir123" | python3 -c \
  "import sys,json; d=json.load(sys.stdin); print('\n'.join(d.get('all',[])))"



curl -X PUT "http://127.0.0.1:9090/proxies/PROXY" \
  -H "Authorization: Bearer aidamir123" \
  -H "Content-Type: application/json" \
  -d '{"name":"🇳🇱 Netherlands"}'