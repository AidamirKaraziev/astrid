# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
# true — весь Bot API через TELEGRAM_PROXY_URL; false — прямое подключение
USE_VPN=false

# Database
DATABASE_URL=postgresql+asyncpg://astra:astra@localhost:5432/astra
# Порт Postgres на хосте (docker compose). Локально 5432; на deadtiger для pgAdmin снаружи — 15432
POSTGRES_HOST_PORT=5432

# GeoNames: автозагрузка справочника городов при старте, если places пуста
GEONAMES_AUTO_IMPORT=true

# Redis
REDIS_URL=redis://localhost:6379/0
# FSM бота: redis (нужен docker redis) или memory (без Redis)
FSM_STORAGE=redis

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_BOT_USERNAME=YourAstraBot
TELEGRAM_MODE=polling
# Proxy только для Bot API (SOCKS5 или HTTP). НЕ tg://proxy (это MTProto для приложения Telegram)
# TELEGRAM_PROXY_URL=socks5://user:pass@proxy.example.com:1080
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/v1/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=random-secret-string

# Points
POINTS_DAILY_VISIT=7
REFERRAL_BONUS_REFERRER=50
REFERRAL_BONUS_INVITEE=10

# Notifications
NOTIFICATION_HOUR=9
NOTIFICATION_MINUTE=0

# RabbitMQ (фоновые задачи: натал, предсказания, рассылка)
RABBITMQ_URL=amqp://astra:astra@localhost:5672/
RABBITMQ_ENABLED=true
RABBITMQ_PREFETCH=8

# Ollama — self-hosted LLM (deadtiger: gemma4:e2b, think=false в коде)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT_SECONDS=300

# Sentry (опционально; в UI: Environment + тег service)
SENTRY_ENABLED=true
SENTRY_DSN=
# Стенд: local | dev | prod (в Sentry → Issues → filter Environment)
SENTRY_ENVIRONMENT=local
# Компонент: api | worker (в docker-compose для worker задаётся worker)
SENTRY_SERVICE=api
# Заголовки запросов и IP пользователей (см. docs.sentry.io data-collected)
SENTRY_SEND_DEFAULT_PII=false
# Доля транзакций для performance monitoring (0.0 — выкл, 1.0 — все)
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Версия релиза в Sentry (по умолчанию astra@<version из pyproject>)
# SENTRY_RELEASE=astra@0.1.0
